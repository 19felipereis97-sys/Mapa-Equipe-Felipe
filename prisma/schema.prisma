// Prisma schema - Mapa da Equipe
// Module 4: Atividades em Grade — adds ActivityStatus with obligationId relation and ActivityStatusHistory

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  ADMIN
  GESTOR
  OPERADOR
  LEITURA
}

model User {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  name         String
  passwordHash String
  role         Role     @default(LEITURA)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

model SystemConfig {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("system_config")
}

model Team {
  id            Int            @id @default(autoincrement())
  name          String
  active        Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  professionals Professional[]
  cellCompanies Company[]      @relation("CompanyCellTeam")

  @@map("teams")
}

model Professional {
  id        Int      @id @default(autoincrement())
  name      String
  teamId    Int?
  email     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  team      Team?    @relation(fields: [teamId], references: [id])

  companiesFinancial Company[] @relation("CompanyFinancial")
  companiesDP        Company[] @relation("CompanyDP")
  companiesFiscal    Company[] @relation("CompanyFiscal")
  companiesAnalysis  Company[] @relation("CompanyAnalysis")
  companiesReview    Company[] @relation("CompanyReview")
  companiesIRRent    Company[] @relation("CompanyIRRent")
  companiesMIT       Company[] @relation("CompanyMIT")

  activityStatuses        ActivityStatus[]        @relation("ActivityResponsible")
  activityStatusHistories ActivityStatusHistory[] @relation("ActivityHistoryResponsible")
  leaves                  Leave[]

  @@map("professionals")
}

model Leave {
  id             Int          @id @default(autoincrement())
  professionalId Int
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  startDate      String // YYYY-MM-DD
  endDate        String // YYYY-MM-DD
  description    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("leaves")
}

model MonthlyGoal {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  month       Int
  year        Int
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("monthly_goals")
}

model DailyGoal {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  date        String // YYYY-MM-DD
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("daily_goals")
}

model TaxRegime {
  id                Int                @id @default(autoincrement())
  name              String
  color             String?
  active            Boolean            @default(true)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  companyTaxRegimes CompanyTaxRegime[]
  deadlines         Deadline[]

  @@map("tax_regimes")
}

model Level {
  id        Int       @id @default(autoincrement())
  name      String
  color     String?
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  companies Company[]

  @@map("levels")
}

model Obligation {
  id        Int        @id @default(autoincrement())
  code      String     @unique
  name      String
  group     String?
  type      String
  order     Int        @default(0)
  isDefault Boolean    @default(false)
  active    Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deadlines Deadline[]

  activityStatuses        ActivityStatus[]
  activityStatusHistories ActivityStatusHistory[]

  @@map("obligations")
}

// Normally one deadline per obligation (taxRegimeId null = applies to every company).
// Financeiro/Análise may additionally have one deadline per tax regime, which takes
// precedence over the general one for companies on that regime.
model Deadline {
  id           Int        @id @default(autoincrement())
  obligationId Int
  taxRegimeId  Int?
  startDay     Int?
  dueDay       Int
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  obligation   Obligation @relation(fields: [obligationId], references: [id])
  taxRegime    TaxRegime? @relation(fields: [taxRegimeId], references: [id], onDelete: Cascade)

  @@unique([obligationId, taxRegimeId])
  @@map("deadlines")
}

model AccountingYear {
  id                Int                @id @default(autoincrement())
  year              Int                @unique
  active            Boolean            @default(false)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  companyTaxRegimes CompanyTaxRegime[]

  @@map("accounting_years")
}

model Company {
  id                     Int      @id @default(autoincrement())
  code                   String?
  groupName              String?
  document               String?
  corporateName          String
  companyType            String?
  unit                   String?
  startCompetence        String?
  levelId                Int?
  operationService       Boolean  @default(false)
  operationCommerce      Boolean  @default(false)
  operationIndustry      Boolean  @default(false)
  irRent                 Boolean  @default(false)
  openingCompany         Boolean  @default(false)
  openingDate            String?
  financialResponsibleId Int?
  dpResponsibleId        Int?
  fiscalResponsibleId    Int?
  analysisResponsibleId  Int?
  reviewResponsibleId    Int?
  irRentResponsibleId    Int?
  mitResponsibleId       Int?
  cellTeamId             Int?
  cell                   String?
  terminated             Boolean  @default(false)
  terminationMonth       String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  level                   Level?                  @relation(fields: [levelId], references: [id])
  financialResponsible    Professional?           @relation("CompanyFinancial", fields: [financialResponsibleId], references: [id])
  dpResponsible           Professional?           @relation("CompanyDP", fields: [dpResponsibleId], references: [id])
  fiscalResponsible       Professional?           @relation("CompanyFiscal", fields: [fiscalResponsibleId], references: [id])
  analysisResponsible     Professional?           @relation("CompanyAnalysis", fields: [analysisResponsibleId], references: [id])
  reviewResponsible       Professional?           @relation("CompanyReview", fields: [reviewResponsibleId], references: [id])
  irRentResponsible       Professional?           @relation("CompanyIRRent", fields: [irRentResponsibleId], references: [id])
  mitResponsible          Professional?           @relation("CompanyMIT", fields: [mitResponsibleId], references: [id])
  cellTeam                Team?                   @relation("CompanyCellTeam", fields: [cellTeamId], references: [id], onDelete: SetNull)
  taxRegimes              CompanyTaxRegime[]
  activityStatuses        ActivityStatus[]
  activityStatusHistories ActivityStatusHistory[]
  closingNotes            ClosingNote[]
  reminders               Reminder[]
  portalNotifications     PortalNotification[]

  @@index([terminated])
  // Ordenação padrão de toda listagem de empresas (groupName, corporateName).
  @@index([groupName, corporateName])
  @@index([levelId])
  // FKs de responsável — preparam a filtragem por responsável no banco (Fase 5),
  // que hoje é feita no cliente sobre o dataset inteiro.
  @@index([financialResponsibleId])
  @@index([dpResponsibleId])
  @@index([fiscalResponsibleId])
  @@index([analysisResponsibleId])
  @@index([reviewResponsibleId])
  @@index([irRentResponsibleId])
  @@index([mitResponsibleId])
  @@map("companies")
}

model ClosingNote {
  id        Int      @id @default(autoincrement())
  companyId Int?
  title     String
  content   String
  pinned    Boolean  @default(false)
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@map("closing_notes")
}

model Reminder {
  id          Int       @id @default(autoincrement())
  companyId   Int?
  text        String
  remindAt    DateTime?
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@map("reminders")
}

// month: 0 = annual (SPED ECD/ECF), 1-12 = monthly
model ActivityStatus {
  id            Int      @id @default(autoincrement())
  companyId     Int
  obligationId  Int
  year          Int
  month         Int
  status        String
  observation   String?
  responsibleId Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  obligation  Obligation    @relation(fields: [obligationId], references: [id])
  responsible Professional? @relation("ActivityResponsible", fields: [responsibleId], references: [id])

  @@unique([companyId, obligationId, year, month])
  @@index([obligationId, year, month])
  @@index([companyId, year])
  @@map("activity_statuses")
}

// Immutable audit trail — never updated, only inserted
model ActivityStatusHistory {
  id             Int      @id @default(autoincrement())
  companyId      Int
  obligationId   Int
  year           Int
  month          Int
  previousStatus String?
  newStatus      String?
  observation    String?
  responsibleId  Int?
  createdAt      DateTime @default(now())

  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  obligation  Obligation    @relation(fields: [obligationId], references: [id])
  responsible Professional? @relation("ActivityHistoryResponsible", fields: [responsibleId], references: [id])

  // Sem nenhum índice até aqui; a trilha de auditoria é consultada por
  // empresa/obrigação/período. Sem isto, cada leitura fazia seq scan.
  @@index([companyId, obligationId, year, month])
  @@map("activity_status_history")
}

model PortalNotification {
  id               Int       @id @default(autoincrement())
  companyId        Int
  cnpj             String
  companyName      String
  notificationDate String
  subject          String
  urgency          String    @default("normal")
  batchName        String
  completed        Boolean   @default(false)
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([completed])
  @@map("portal_notifications")
}

model CompanyTaxRegime {
  id               Int      @id @default(autoincrement())
  companyId        Int
  accountingYearId Int
  taxRegimeId      Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  company        Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  accountingYear AccountingYear @relation(fields: [accountingYearId], references: [id])
  taxRegime      TaxRegime      @relation(fields: [taxRegimeId], references: [id])

  @@unique([companyId, accountingYearId])
  @@index([companyId])
  @@map("company_tax_regimes")
}

// Uma linha por tarefa importada da planilha do G-Click. sourceKey identifica
// a mesma tarefa entre importações (departamento+assunto+cliente+competência+
// ação+meta), permitindo reimportar sem duplicar nem perder o status de
// conclusão já marcado localmente.
model GClickTask {
  id        Int    @id @default(autoincrement())
  sourceKey String @unique

  status         String // coluna "Status" (status original do G-Click, informativo)
  department     String // "Departamento"
  subject        String // "Assunto"
  competence     String // "Competência", texto original (ex: "JAN/2026")
  competenceSort Int? // ano*12+mês, para ordenação cronológica; null se não parseável
  clientCode     String? // extraído do texto de "Cliente", se houver um código no início
  clientName     String // "Cliente" (nome, ou o texto inteiro se não houver código)
  clientStatus   String? // "Status Cliente"
  action         String? // "Ação"
  goal           String? // "Meta"
  dueDate        DateTime? // "Vencimento", parseado
  dueDateRaw     String? // texto original do vencimento, para exibir se não for parseável

  completed   Boolean   @default(false)
  completedAt DateTime?
  completedBy String? // reservado para quando houver login de usuário

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subject])
  @@index([clientName])
  @@index([completed])
  @@index([dueDate])
  @@map("gclick_tasks")
}

// ─── FASE 2 — Persistência de tarefas, resultados e observabilidade ───
// Tabelas de suporte à fila (worker loop Postgres) e ao pré-processamento.
// Nesta fase são apenas criadas; os agents/worker que as preenchem vêm na Fase 3.

enum TaskStatus {
  AGUARDANDO
  PROCESSANDO
  CONCLUIDO
  CONCLUIDO_COM_ALERTAS
  ERRO
  CANCELADO
  PENDENTE_REVISAO
}

// Fila de processamento pesado. O worker seleciona a próxima tarefa AGUARDANDO
// com FOR UPDATE SKIP LOCKED, ordenando por prioridade (menor = mais urgente) e
// data de criação. tipo é string livre (GCLICK_IMPORT, REPORT_PDF, INDICATORS…)
// para não exigir migration a cada novo agent.
model TarefaProcessamento {
  id                   Int        @id @default(autoincrement())
  tipo                 String
  status               TaskStatus @default(AGUARDANDO)
  prioridade           Int        @default(100) // menor = mais urgente
  params               Json?
  resultRef            String? // storagePath / id de snapshot / id de relatório
  mensagemUsuario      String?
  userId               Int?
  tentativas           Int        @default(0)
  maxTentativas        Int        @default(3)
  proximaTentativaEm   DateTime?
  lockedBy             String? // id do worker que reservou a tarefa
  lockedAt             DateTime?
  erroResumo           String?
  erroDetalhado        String?
  registrosProcessados Int?
  durationMs           Int?
  createdAt            DateTime   @default(now())
  startedAt            DateTime?
  finishedAt           DateTime?
  updatedAt            DateTime   @updatedAt

  logs  LogProcessamento[]
  erros ErroProcessamento[]

  @@index([status, prioridade, createdAt])
  @@index([tipo])
  @@index([userId])
  @@map("tarefas_processamento")
}

// Rastreabilidade do arquivo original importado (antes de qualquer processamento).
// hash permite detectar reimportação do mesmo arquivo.
model ArquivoImportado {
  id           Int      @id @default(autoincrement())
  nomeOriginal String
  hash         String
  tamanho      Int
  tipo         String // gclick | empresas | portais
  mimeType     String?
  storagePath  String?
  userId       Int?
  status       String   @default("recebido")
  createdAt    DateTime @default(now())

  @@index([hash])
  @@index([userId])
  @@index([tipo])
  @@map("arquivos_importados")
}

// Snapshot do dashboard por período. chave ex.: "dashboard:2026:7".
model IndicadorProcessado {
  id                  Int      @id @default(autoincrement())
  chave               String   @unique
  ano                 Int
  mes                 Int
  payload             Json
  recalculationReason String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([ano, mes])
  @@map("indicadores_processados")
}

// Grupos/cards pré-processados (G-Click, grade de atividades). chave identifica
// o recorte; versao/sourceRef ajudam a invalidar quando a origem muda.
model CardProcessado {
  id        Int      @id @default(autoincrement())
  chave     String   @unique
  tipo      String
  payload   Json
  versao    Int      @default(1)
  sourceRef String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tipo])
  @@map("cards_processados")
}

// Relatórios (PDF/Excel) gerados em background e salvos em storage.
model RelatorioGerado {
  id          Int        @id @default(autoincrement())
  tipo        String
  filtros     Json?
  storagePath String?
  status      TaskStatus @default(AGUARDANDO)
  userId      Int?
  expiresAt   DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([tipo])
  @@index([userId])
  @@index([expiresAt])
  @@map("relatorios_gerados")
}

// Log estruturado por etapa de processamento. taskId nulo = log fora de uma
// tarefa da fila (ex.: bulk inline).
model LogProcessamento {
  id                   Int      @id @default(autoincrement())
  taskId               Int?
  etapa                String
  mensagem             String?
  durationMs           Int?
  registrosProcessados Int?
  metadata             Json?
  createdAt            DateTime @default(now())

  task TarefaProcessamento? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([etapa])
  @@index([createdAt])
  @@map("logs_processamento")
}

// Erros técnicos e falhas definitivas.
model ErroProcessamento {
  id            Int      @id @default(autoincrement())
  taskId        Int?
  etapa         String
  erroResumo    String
  erroDetalhado String?
  stack         String?
  metadata      Json?
  createdAt     DateTime @default(now())

  task TarefaProcessamento? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([etapa])
  @@map("erros_processamento")
}
