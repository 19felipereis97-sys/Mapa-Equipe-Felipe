# Copy this file to .env and fill in the values
# Never commit .env to version control

# Database - PostgreSQL (Supabase)
# DATABASE_URL: pooled connection (port 6543), used by the app at runtime
# DIRECT_URL: direct connection (port 5432), used by Prisma Migrate
DATABASE_URL="postgresql://postgres.xxxxx:PASSWORD@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxxx:PASSWORD@aws-0-region.pooler.supabase.com:5432/postgres"

# Application
NODE_ENV="development"
NEXT_TELEMETRY_DISABLED=1

# Storage (arquivos importados e relatórios gerados)
# Sem as variáveis SUPABASE_* abaixo, usa disco local em STORAGE_DIR (default ./data/storage).
# STORAGE_DIR="/data/storage"
# Para usar Supabase Storage, defina as 3 variáveis (crie o bucket antes):
# SUPABASE_URL="https://xxxxx.supabase.co"
# SUPABASE_SERVICE_ROLE_KEY="<service_role_key>"
# SUPABASE_STORAGE_BUCKET="mapa-equipe"

# Worker in-process (fila). WORKER_ENABLED=false desliga; WORKER_POLL_MS ajusta o poll.
# WORKER_ENABLED=true
# WORKER_POLL_MS=1500

# Auth.js (NextAuth v5)
# Gere um segredo com: openssl rand -base64 32   (ou: npx auth secret)
AUTH_SECRET="troque-por-um-segredo-forte-gerado"
# Em produção atrás de proxy/HTTPS, defina a URL pública:
# AUTH_URL="https://seu-dominio"
# AUTH_TRUST_HOST=true

# Internal use only - no public exposure
# HOST=localhost
# PORT=3000
